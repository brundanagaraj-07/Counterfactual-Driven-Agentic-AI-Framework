# .env.example — Copy to .env and fill in your keys
# Never commit .env to version control

# ── LLM ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── News APIs ───────────────────────────────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here          # https://newsapi.org/register
# GNEWS_API_KEY=your_gnews_key_here          # https://gnews.io/ — disabled for now
# THENEWSAPI_KEY=your_thenewsapi_key_here    # https://www.thenewsapi.com/ — disabled for now

# ── Social ──────────────────────────────────────────────────────────────────
# Reddit posts now use Pushshift API (free, no keys required)
# Pushshift: https://pushshift.io/ — public archive, no authentication needed

# ── Stock & Macro ────────────────────────────────────────────────────────────
ALPHA_VANTAGE_KEY=your_alpha_vantage_key   # https://www.alphavantage.co/support/
FRED_API_KEY=your_fred_api_key             # https://fred.stlouisfed.org/docs/api/api_key.html
# yfinance needs no key

# ── Port / Shipping ──────────────────────────────────────────────────────────
VESSELFINDER_API_KEY=your_key_optional     # https://www.vesselfinder.com/api (limited free)
# UN Comtrade needs no key for public endpoint

# ── Weather ──────────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_key   # https://openweathermap.org/api
# Open-Meteo needs no key

# ── Commodities ──────────────────────────────────────────────────────────────
COMMODITIES_API_KEY=your_key_optional      # https://commodities-api.com/ (optional, FRED is fallback)
